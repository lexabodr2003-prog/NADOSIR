                                                                            {% for page_link in oct_page.page_links %}
                                                                            <a href="{{ page_link[language_id].link }}" title="{{ page_link[language_id].title }}" class="ds-menu-list-landings-link fsz-14">{{ page_link[language_id].title }}</a>
                                                                            {% endfor %}
                                                                        </li>
                                                                        {% endif %}
                                                                    {% endfor %}
                                                                </ul>
                                                            {% endif %}
                                                        </div>
                                                    </div>
                                                {% endif %}
                                            </li>
                                        {% endfor %}
                                        {% if oct_category.oct_pages and oct_category.view == '1' %}
                                            <li class="ds-menu-list-landings">
                                                <ul>
                                                    {% for oct_page in oct_category.oct_pages %}
