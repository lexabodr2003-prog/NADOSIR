<div class="ocf-container {{ ocf_class }} ocf-theme-{{ theme }} ocf-mobile-{{ index }} ocf-mobile-{{ mobile_placement }} ocf-{{ layout }} ocf-{{ position }}" id="ocf-module-{{ index }}">
{% if index < 2 %}
<link rel="stylesheet" href="{{ stylesheet }}" />
{% endif %}

  <div class="ocf-content">
    <div class="ocf-header">
      <i class="ocf-icon ocf-icon-16 ocf-brand ocf-sliders"></i>      
      
      {{ heading_title }}
      
      {% if layout == 'horizontal' and (search_button or selecteds) %}
      <div class="ocf-header-btn ocf-desktop">
        {% if selecteds %}
        <button type="button" onclick="location = '{{ link }}';" class="ocf-btn ocf-btn-link">{{ button_cancel_all }}</button>
        {% else %}
        <button type="button" data-ocf-discard="*" class="ocf-btn ocf-btn-link ocf-disabled" disabled="disabled">{{ button_cancel_all }}</button>
        {% endif %}         
        {% if search_button %}
        <button type="button" class="ocf-btn ocf-btn-link ocf-disabled" data-ocf="button" data-loading-text="{{ text_loading_ocf }}" disabled="disabled">{{ button_select }}</button>
        {% endif %}        
      </div>   
      {% endif %}  
      
      <button type="button" data-ocf="mobile" class="ocf-btn ocf-btn-link ocf-mobile ocf-close-mobile" aria-label="Close filter"><i class="ocf-icon ocf-icon-16 ocf-times"></i></button>
    </div>
          
    <div class="ocf-body">     
      {% include('default/template/extension/module/ocfilter48/filter_list.twig') %}
    </div>      
       
    {% if search_button or selecteds %}
    {% if layout == 'vertical' %}
    {% set class = 'ocf-footer' %}
    {% else %}
    {% set class = 'ocf-footer ocf-mobile' %}
    {% endif %}
    <div class="{{ class }}">
      <div class="ocf-between">
        {% if selecteds %}
        <button type="button" onclick="location = '{{ link }}';" class="ocf-btn ocf-btn-link">{{ button_cancel_all }}</button>
        {% else %}
        <button type="button" data-ocf-discard="*" class="ocf-btn ocf-btn-link ocf-disabled" disabled="disabled">{{ button_cancel_all }}</button>
        {% endif %}        
        {% if search_button %}
        <button type="button" class="ocf-btn ocf-disabled ocf-btn-block ocf-search-btn-static" data-ocf="button" data-loading-text="{{ text_loading_ocf }}" disabled="disabled">{{ button_select }}</button>
        {% endif %}        
      </div>
    </div>            
    {% endif %}
  </div><!-- /.ocf-content -->
  
  <div class="ocf-is-mobile"></div>
  
  {% if (mobile_button_position == 'fixed' or mobile_button_position == 'both') and index < 2 %}
  <div class="ocf-btn-mobile-fixed ocf-mobile">
    <button type="button" class="ocf-btn ocf-btn-default" data-ocf="mobile" aria-label="{{ button_ocfilter_mobile }}">
      <span class="ocf-btn-name">{{ button_ocfilter_mobile }}</span>
      <i class="ocf-icon ocf-icon-16 ocf-brand ocf-sliders"></i>
    </button>
  </div>  
  {% endif %} 
  
  <div class="ocf-hidden">
    <button class="ocf-btn ocf-search-btn-popover" data-ocf="button" data-loading-text="{{ text_loading_ocf }}">{{ button_select }}</button>
  </div>
  
<script>
+(function(global) {

var startOCFilter = function() {
  // ============================================================
  // loadScript v6.0 - iOS Safari / Yandex Browser fix
  // Primary: XHR + eval (bypasses iOS script tag async issues)
  // Fallback: native <script> tag injection
  // ============================================================
  var loadScript = function(url, callback) {
    // Make URL absolute (iOS Safari may ignore <base href> for dynamic script.src)
    var absUrl = url;
    if (url.indexOf('http') !== 0 && url.indexOf('//') !== 0) {
      absUrl = window.location.protocol + '//' + window.location.host + '/' +
        url.replace(/^\/+/, '');
    }

    // Already loaded?
    if (typeof $.fn.ocfilter !== 'undefined') {
      setTimeout(callback, 0);
      return;
    }

    // Check if script tag already in DOM
    var existing = null;
    try {
      var allScripts = document.querySelectorAll('script[src]');
      for (var si = 0; si < allScripts.length; si++) {
        if (allScripts[si].src && allScripts[si].src.indexOf('ocfilter48/ocfilter') !== -1) {
          existing = allScripts[si];
          break;
        }
      }
    } catch(e) {}

    if (existing) {
      // Tag in DOM - wait for plugin to be defined
      var waitExec = 0;
      var checkLoaded = setInterval(function() {
        waitExec++;
        if (typeof $.fn.ocfilter !== 'undefined') {
          clearInterval(checkLoaded);
          callback();
        } else if (waitExec > 400) { // 20s timeout
          clearInterval(checkLoaded);
          loadViaXHR(absUrl, callback); // last resort
        }
      }, 50);
      return;
    }

    // Primary method: XHR + eval (reliable on iOS Safari)
    loadViaXHR(absUrl, callback);
  };

  function loadViaXHR(absUrl, callback) {
    // Cache-bust: refresh every 5 minutes
    var cbUrl = absUrl.split('?')[0] + '?v=4.8.2&_t=' + Math.floor(Date.now() / 300000);
    try {
      var xhr = new XMLHttpRequest();
      xhr.open('GET', cbUrl, true);
      xhr.onreadystatechange = function() {
        if (xhr.readyState !== 4) return;
        if (xhr.status === 200) {
          try {
            // Execute in global scope
            (new Function(xhr.responseText)).call(window);
          } catch(e1) {
            try { (0, eval)(xhr.responseText); } catch(e2) {}
          }
          setTimeout(function() {
            if (typeof $.fn.ocfilter !== 'undefined') {
              callback();
            } else {
              loadViaTag(absUrl, callback);
            }
          }, 50);
        } else {
          loadViaTag(absUrl, callback);
        }
      };
      xhr.onerror = function() { loadViaTag(absUrl, callback); };
      xhr.send();
    } catch(e) {
      loadViaTag(absUrl, callback);
    }
  }

  function loadViaTag(absUrl, callback) {
    var s = document.createElement('script');
    s.type = 'text/javascript';
    s.src = absUrl;
    s.onload = s.onreadystatechange = function() {
      if (!s.readyState || s.readyState === 'loaded' || s.readyState === 'complete') {
        s.onload = s.onreadystatechange = null;
        setTimeout(function() {
          if (typeof $.fn.ocfilter !== 'undefined') callback();
        }, 50);
      }
    };
    s.onerror = function() {
      console.warn('OCFilter: all load methods failed');
    };
    (document.head || document.body).appendChild(s);
  }
  
  var init = function() {
    // Store config BEFORE calling ocfilter() - used by ocfilter-mobile-fix.js
    var cfg = {
      index: '{{ index }}',
      paramsIndex: '{{ url_index }}',
      urlHost: '{{ url_host }}',
      urlParams: '{{ url_params }}',
      params: '{{ filter_params }}',
      sepFilt: '{{ sep_filt }}',
      sepFsrc: '{{ sep_fsrc }}',
      sepVals: '{{ sep_vals }}',
      sepSdot: '{{ sep_sdot }}',
      sepSneg: '{{ sep_sneg }}',
      sepSran: '{{ sep_sran }}',
      position: '{{ position }}',
      layout: '{{ layout }}',
      numeralLocale: '{{ numeral_locale }}',
      searchButton: {{ search_button + 0 }},
      showCounter: {{ show_counter + 0 }},
      sliderInput: {{ slider_input + 0 }},
      sliderPips: {{ slider_pips + 0 }},
      priceLogarithmic: {{ price_logarithmic + 0 }},
      lazyLoadFilters: {{ hidden_filters_lazy_load + 0 }},
      lazyLoadValues: {{ hidden_values_lazy_load + 0 }},
      mobileMaxWidth: {{ mobile_max_width + 0 }},
      mobileRememberState: {{ mobile_remember_state + 0 }},
      textLoad: '{{ text_loading_ocf|e('js') }}',
      textSelect: '{{ button_select|e('js') }}'
    };

    // Save config and JS URL for external reinit (ocfilter-mobile-fix.js)
    window['_ocf_config_{{ index }}'] = cfg;
    window['_ocf_js_url_{{ index }}'] = '{{ javascript }}';

    if (typeof $.fn.ocfilter !== 'undefined') {
      $('#ocf-module-{{ index }}').ocfilter(cfg);
    }
  };
  
  {% if index < 2 %}
  loadScript('{{ javascript }}', init);
  {% else %}
  init();
  {% endif %}
};

var ready = function(fn) {
  if (global.readyState != 'loading') {
    fn();
  } else {
    global.addEventListener('DOMContentLoaded', fn);
  }
};

ready(function() { // DOM loaded
  // Wait for jQuery (handles async/cached bundle loading)
  var jqWaitTries = 0;
  var waitForJQ = function() {
    jqWaitTries++;
    if (jqWaitTries > 300) { // 15s timeout
      console.error('OCFilter: jQuery not available');
      return;
    }
    if (typeof jQuery !== 'undefined') {
      jQuery(startOCFilter); // jQuery ready
    } else {
      setTimeout(waitForJQ, 50);
    }
  };
  waitForJQ();
});

})(document);
</script>
</div><!-- /.ocf-container -->
