{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
  <div class="container-fluid">
    <div class="pull-right">
        <button type="submit" form="form-edit" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3> <a href="http://sourcedistillery.com/market_yml_faq.html" target="_blank">F.A.Q.</a>
      </div>
      <div class="panel-body">
	  
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-edit" class="form-horizontal">
          <ul class="nav nav-tabs">
            <li class="active"><a href="#tab-general" data-toggle="tab">{{ tab_general }}</a></li>
            <li><a href="#tab-available" data-toggle="tab">{{ tab_available }}</a></li>
            <li><a href="#tab-categories" data-toggle="tab">{{ tab_categories }}</a></li>
            <li><a href="#tab-attributes" data-toggle="tab">{{ tab_attributes }}</a></li>
            <li><a href="#tab-tailor" data-toggle="tab">{{ tab_tailor }}</a></li>
            <li><a href="#tab-promo" data-toggle="tab">Промоакции</a></li>
          </ul>

        <div class="tab-content">
		
        <div class="tab-pane active" id="tab-general">
				
			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-status">{{ entry_status }}</label>
				<div class="col-sm-9">
				  <select name="yandex_yml_status" id="input- status" class="form-control">
					{% if yandex_yml_status %}
					<option value="1" selected="selected">{{ text_enabled }}</option>
					<option value="0">{{ text_disabled }}</option>
					{% else %}
					<option value="1">{{ text_enabled }}</option>
					<option value="0" selected="selected">{{ text_disabled }}</option>
					{% endif %}
					</select>
				</div>
			</div>

			<div class="form-group">
				<label class="col-sm-3 control-label"><span data-toggle="tooltip" title="{{ entry_token_help }}">{{ entry_token }}</span></label>
				<div class="col-sm-9">
					<input type="text" name="yandex_yml_token" value="{{ yandex_yml_token }}" id="input-token" class="form-control" />
				</div>
			</div>
			
			<div class="form-group">
				<label class="col-sm-3 control-label"><span data-toggle="tooltip" title="{{ entry_data_feed_help }}">{{ entry_data_feed }}</span></label>
				<div class="col-sm-9">
					<b><a href="{{ data_feed }}{% if yandex_yml_token %}&token={{ yandex_yml_token }}{% endif %}" target="_blank" id="yml_feed_url">
                        {{ data_feed }}{% if yandex_yml_token %}&token={{ yandex_yml_token }}{% endif %}</a></b>
				</div>
			</div>
			
			<div class="form-group">
				<label class="col-sm-3 control-label"><span data-toggle="tooltip" title="{{ entry_cron_run_help }}">{{ entry_cron_run }}</span></label>
				<div class="col-sm-9">
					<b>{{ cron_path }}</b>
				</div>
			</div>			
			
			<div class="form-group">
				<label class="col-sm-3 control-label"><span data-toggle="tooltip" title="{{ entry_export_url_help }}">{{ entry_export_url }}</span></label>
				<div class="col-sm-9">
					<b id="yml_static_file">{{ export_url }}{{ CONFIG_PREFIX }}{{ yandex_yml_token }}.xml</b>
				</div>
			</div>

			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-ocstore"><span data-toggle="tooltip" title="{{ entry_ocstore_help }}">{{ entry_ocstore }}</span></label>
				<div class="col-sm-9">
				<div class="checkbox">
				<label><input type="checkbox" name="yandex_yml_ocstore" id="input-ocstore" value="1"
                         {% if yandex_yml_ocstore %} checked="checked"{% endif %} />
                </label>
				</div>
				</div>
			</div>
			
			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-datamodel"><span data-toggle="tooltip" title="{{ entry_datamodel_help }}">{{ entry_datamodel }}</span></label>
				<div class="col-sm-9">
					<select name="yandex_yml_datamodel" id="input-datamodel" class="form-control">
                    {% for key,datamodel in datamodels %}
					<option value="{{ key }}"{% if key == yandex_yml_datamodel %} selected="selected"{% endif %}>
					{{ datamodel }}
					</option>
                    {% endfor %}
					</select>
				</div>
			</div>
				
			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-name-field">{{ entry_name_field }}</label>
				<div class="col-sm-9">
					<select name="yandex_yml_name_field" id="input-name-field" class="form-control">
                    {% for key,name in oc_fields %}
					<option value="{{ key }}"{% if key == yandex_yml_name_field %} selected="selected"{% endif %}>
					{{ name }}
					</option>
                    {% endfor %}
					</select>
					<a href="https://yandex.ru/support/partnermarket/elements/vendor-name-model.html" target="_blank">подробнее</a>
				</div>
			</div>
			
			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-model-field">{{ entry_model_field }}</label>
				<div class="col-sm-9">
					<select name="yandex_yml_model_field" id="input-model-field" class="form-control">
					<option value="">{{ entry_dont_export }}</option>
                    {% for key,name in oc_fields %}
					<option value="{{ key }}"{% if key == yandex_yml_model_field %} selected="selected"{% endif %}>
					{{ name }}
					</option>
                    {% endfor %}
					</select>
                    <span style="color: red;">При vendor.model model будет выгружаться</span>
				</div>
			</div>				
				
			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-vendorcode-field">{{ entry_vendorcode_field }}</label>
				<div class="col-sm-9">
					<select name="yandex_yml_vendorcode_field" id="input-vendorcode-field" class="form-control">
					<option value="">{{ entry_dont_export }}</option>
                    {% for key,name in oc_fields %}
					<option value="{{ key }}"{% if key == yandex_yml_vendorcode_field %} selected="selected"{% endif %}>
					{{ name }}
					</option>
                    {% endfor %}
					</select>
				</div>
			</div>
			
			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-typeprefix-field">{{ entry_typeprefix_field }}</label>
				<div class="col-sm-9">
					<select name="yandex_yml_typeprefix_field" id="input-typeprefix-field" class="form-control">
					<option value="">{{ entry_dont_export }}</option>
                    {% for key,name in oc_fields %}
					<option value="{{ key }}"{% if key == yandex_yml_typeprefix_field %} selected="selected"{% endif %}>
					{{ name }}
					</option>
                    {% endfor %}
					</select>
				</div>
			</div>

			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-barcode-field">{{ entry_barcode_field }}</label>
				<div class="col-sm-9">
					<select name="yandex_yml_barcode_field" id="input-barcode-field" class="form-control">
					<option value="">{{ entry_dont_export }}</option>
                    {% for key,name in oc_fields %}
					<option value="{{ key }}"{% if key == yandex_yml_barcode_field %} selected="selected"{% endif %}>
					{{ name }}
					</option>
                    {% endfor %}
					</select>
				</div>
			</div>

            <div class="form-group">
                <label class="col-sm-3 control-label" for="input-sales_notesattr" data-toggle="tooltip" title="sales_notes в первую очередь берется из атрибута, во вторую из настроек категорий и производителей, иначе из поля &quot;Примечания sales_notes&quot;"><span>Брать тэг sales_notes из атрибута</span></label>
                <div class="col-sm-9">
                    <select name="yandex_yml_sales_notesattr" id="input-sales_notesattr" class="form-control">
                    <option value="0">Атрибуты не учитывать</option>
                    {% set attr_group_id = -1 %}
					{% for key,attribute in attributes %}
                        {% if attr_group_id != attribute.attribute_group_id %}
                            <optgroup label="{{ attribute.attribute_group }}">
							{% set attr_group_id = attribute.attribute_group_id %}
                        {% endif %}
                        <option value="{{ attribute.attribute_id }}" {%if yandex_yml_sales_notesattr == attribute.attribute_id %} selected="selected"{% endif %}>{{ attribute.name }}</option>
						{% set key_1 = key+1 %}
                        {% if attributes[key_1] is not defined or attr_group_id != attributes[key_1].attribute_group_id %}
                            </optgroup>
                        {% endif %}
                    {% endfor %}
                    </select>
                    <a href="https://yandex.ru/support/partnermarket/elements/sales_notes.html" target="_blank">подробнее</a>
                </div>
            </div>
			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-sales-notes"><span data-toggle="tooltip" title="{{ entry_sales_notes_help }}">{{ entry_sales_notes }}</span></label>
				<div class="col-sm-9">
					<input type="text" name="yandex_yml_sales_notes" value="{{ yandex_yml_sales_notes }}" id="input-sales-notes" maxlength="50" class="form-control" />
				</div>
			</div>

			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-keyword-field">{{ entry_keywords_field }}</label>
				<div class="col-sm-9">
					<select name="yandex_yml_keywords_field" id="input-keyword-field" class="form-control">
					<option value="">{{ entry_dont_export }}</option>
                    {% for key,name in oc_fields %}
					<option value="{{ key }}"{% if key == yandex_yml_keywords_field %} selected="selected"{% endif %}>
						{{ name }}
					</option>
                    {% endfor %}
					</select>
                    <span style="color: red;">Для Яндекс.Маркет не выгружать</span>
				</div>
			</div>

			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-shop-sku">Выгружать shop-sku из product_id</label>
				<div class="col-sm-9">
                    <div class="checkbox">
                    <label>
					<input type="checkbox" name="yandex_yml_shop_sku" value="1" id="input-shop-sku"{%if yandex_yml_shop_sku %} checked="checked"{% endif %} />
                    </label>
                    <span style="color: red;">Выгружать для Яндекс.Маркет DBS, FBS</span> <a href="https://yandex.ru/support/marketplace/catalog/yml-simple.html" target="_blank">подробнее</a>
                    </div>
				</div>
			</div>
            
			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-market-sku-field">Брать тэг market-sku из поля</label>
				<div class="col-sm-9">
					<select name="yandex_yml_market_sku_field" id="input-market-sku-field" class="form-control">
					<option value="">{{ entry_dont_export }}</option>
					{% for key,name in oc_fields %}
					<option value="{{ key }}"{% if key == yandex_yml_market_sku_field %} selected="selected"{% endif %}>
						{{ name }}
					</option>
                    {% endfor %}
					</select>
                    <span style="color: red;">Для Яндекс.Маркет не выгружать (для beru.ru)</span> <a href="https://yandex.ru/support/marketplace/catalog/yml-elements.html" target="_blank">подробнее</a>
				</div>
			</div>

			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-manufacturer-field">Брать тэг manufacturer из поля</label>
				<div class="col-sm-9">
					<select name="yandex_yml_manufacturer_field" id="input-manufacturer-field" class="form-control">
					<option value="">{{ entry_dont_export }}</option>
					{% for key,name in oc_fields %}
					<option value="{{ key }}"{% if key == yandex_yml_manufacturer_field  %} selected="selected"{% endif %}>
						{{ name }}
					</option>
                    {% endfor %}
					</select>
                    <span style="color: red;">Для Яндекс.Маркет не выгружать (для beru.ru)</span> <a href="https://yandex.ru/support/marketplace/catalog/yml-elements.html" target="_blank">подробнее</a>
				</div>
			</div>
			
			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-description-field">{{ entry_description_field }}</label>
				<div class="col-sm-9">
					<select name="yandex_yml_description_field" id="input-description-field" class="form-control">
					<option value="">{{ entry_dont_export }}</option>
                    {% for key,name in oc_desc_fields %}
					<option value="{{ key }}"{% if key == yandex_yml_description_field %} selected="selected"{% endif %}>
					{{ name }}
					</option>
                    {% endfor %}
					</select>
				</div>
			</div>
				
			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-export_tags"><span data-toggle="tooltip" title="{{ entry_export_tags_help }}">{{ entry_export_tags }}</span></label>
				<div class="col-sm-9">
				<div class="checkbox">
                    <label><input type="checkbox" name="yandex_yml_export_tags" id="input-export_tags" value="1"
                            {% if yandex_yml_export_tags %} checked="checked"{% endif %} />
                    </label>
				</div>
				</div>
			</div>

			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-group_id_attr">{{ entry_group_id_attr }}</label>
				<div class="col-sm-9">
				<div class="checkbox">
				<label><input type="checkbox" name="yandex_yml_group_id_attr" id="input-group_id_attr" value="1"
                    {% if yandex_yml_group_id_attr %} checked="checked"{% endif %} /></label>
				<span style="color: red;">Для Яндекс.Маркет не включать (для Aliexpress)</span>
				</div>
				</div>
			</div>
			
			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-utm_label"><span data-toggle="tooltip" title="{{ entry_utm_label_help }}">{{ entry_utm_label }}</span></label>
				<div class="col-sm-9">
				    <input type="text" name="yandex_yml_utm_label" value="{{ yandex_yml_utm_label }}" class="form-control">
				</div>
			</div>

			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-currency"><span data-toggle="tooltip" title="{{ entry_currency_help }}">{{ entry_currency }}</span></label>
				<div class="col-sm-9">
                    <select name="yandex_yml_currency" id="input-currency" class="form-control">
                    {% for currency in currencies %}
                        {% if currency.code == yandex_yml_currency %}
                        <option value="{{ currency.code }}" selected="selected">({{ currency.code }}) {{ currency.title }}</option>
                        {% else %}
                        <option value="{{ currency.code }}">({{ currency.code }}) {{ currency.title }}</option>
                        {% endif %}
                    {% endfor %}
                    </select>
				</div>
			</div>

			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-oldprice"><span data-toggle="tooltip" title="{{ entry_oldprice_help }}">{{ entry_oldprice }}</span></label>
				<div class="col-sm-9">
				<div class="checkbox">
				    <label><input type="checkbox" name="yandex_yml_oldprice" id="input-oldprice" value="1"
                        {% if yandex_yml_oldprice %} checked="checked"{% endif %} />
                    </label>
				</div>
				</div>
			</div>
            
			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-price_promo"><span data-toggle="tooltip" title="В тэге price будет цена без скидки">Выгружать тэг price_promo</span></label>
				<div class="col-sm-9">
				<div class="checkbox">
				<label><input type="checkbox" name="yandex_yml_price_promo" id="input-price_promo" value="1"{%if yandex_yml_price_promo %} checked="checked"{% endif %}></label>
				<span style="color: red;">Для Яндекс.Маркет не включать (для Aliexpress)</span>
				</div>
				</div>
			</div>
				
			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-groupprice"><span data-toggle="tooltip" title="{{ entry_groupprice_help }}">{{ entry_groupprice }}</span></label>
				<div class="col-sm-9">
				<select name="yandex_yml_groupprice" id="input-groupprice" class="form-control">
				{% for customer_group in customer_groups %}
                    {% if customer_group.customer_group_id == yandex_yml_groupprice %}
                    <option value="{{ customer_group.customer_group_id }}" selected="selected">{{ customer_group.name }}</option>
                    {% else %}
                    <option value="{{ customer_group.customer_group_id }}">{{ customer_group.name }}</option>
                    {% endif %}
				{% endfor %}
				</select>
				</div>
			</div>

			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-purchase_price">Выгружать закупочные цены в тэге<br>purchase_price из поля</label>
				<div class="col-sm-9">
                    {% set purchase_price_fields = {
                            'ean' : 'EAN - ean',
                            'jan' : 'JAN - jan',
                            'isbn' : 'ISBN - isbn',
                            'mpn' : 'MPN - mpn',
                            'cost' : 'Закупочная цена - cost'
                        }
                    %}
					<select name="yandex_yml_purchase_price" id="input-purchase_price" class="form-control">
					<option value="">{{ entry_dont_export }}</option>
                    {% for key,name in purchase_price_fields %}
					<option value="{{ key }}"{% if key == yandex_yml_purchase_price %} selected="selected"{% endif %}>
					{{ name }}
					</option>
                    {% endfor %}
					</select>
                    <a href="https://yandex.ru/support/pricelabs/rate/rate-marg.html" target="_blank">подробнее</a>
				</div>
			</div>

			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-changeprice"><span data-toggle="tooltip" title="{{ entry_changeprice_help }}">{{ entry_changeprice }}</span></label>
				<div class="col-sm-9">
				<label><input type="text" class="form-control" name="yandex_yml_changeprice" id="input-changeprice" value="{{ yandex_yml_changeprice }}"></label>
				</div>
			</div>
			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-addprice"><span data-toggle="tooltip" title="Указать в валюте прайслиста">Выгружать цены с наценкой/скидкой</span></label>
				<div class="col-sm-9">
					<label><input type="text" class="form-control" name="yandex_yml_addprice" id="input-addprice" value="{{ yandex_yml_addprice }}"></label>
				</div>
			</div>

			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-numpictures"><span data-toggle="tooltip" title="{{ entry_numpictures_help }}">{{ entry_numpictures }}</span></label>
				<div class="col-sm-9">
					<label><input type="text" name="yandex_yml_numpictures" value="{{ yandex_yml_numpictures }}" id="input-numpictures" class="form-control" /></label>
				</div>
			</div>

			<div class="form-group">
				<label class="col-sm-3 control-label" for="input-vats"><span data-toggle="tooltip" title="Если не заполнено, Маркет устанавливает ставку, соответствующую схеме налогообложения в настройках магазина.">Выгружать ставки НДС:</span></label>
				<div class="col-sm-9">
					<div class="well well-sm" style="height: 200px; overflow-y: auto; overflow-x: hidden;">
						{% for tax_class in tax_classes %}
							<div class="checkbox row-fluid">
								{{ tax_class.title }}
								<select name="yandex_yml_vats[{{ tax_class.tax_class_id }}]" style="float:right;">
									{% set yandex_yml_vat = yandex_yml_vats[ tax_class.tax_class_id ] %}
									<option value=""{% if not yandex_yml_vat %} selected="selected"{% endif %}>{{ entry_dont_export }}</option>
									{% for key,item in vats_list %}
									<option value="{{ key }}"{% if yandex_yml_vat == key %} selected="selected"{% endif %}>{{ item }}</option>
									{% endfor %}
								</select>
							</div>
						{% endfor %}
					</div>
				</div>
			</div>

		</div>

		<div class="tab-pane" id="tab-available">
		
			<div class="form-group">
				<label class="col-sm-3 control-label"><span data-toggle="tooltip" title="{{ entry_store_help }}">{{ entry_store }}</span></label>
				<div class="col-sm-9">
                    {% if yandex_yml_store %}
					<label class="radio-inline">
						<input type="radio" name="yandex_yml_store" value="1" checked="checked" />
						{{ text_yes }}
					</label>
					<label class="radio-inline">
						<input type="radio" name="yandex_yml_store" value="0" />
						{{ text_no }}
					</label>
                    {% else %}
					<label class="radio-inline">
						<input type="radio" name="yandex_yml_store" value="1" />
						{{ text_yes }}
					</label>
					<label class="radio-inline">
						<input type="radio" name="yandex_yml_store" value="0" checked="checked" />
						{{ text_no }}
					</label>
					{% endif %}
				</div>
			</div>
			
			<div class="form-group">
				<label class="col-sm-3 control-label" for="unavailable"><span data-toggle="tooltip" title="{{ entry_unavailable_help }}">{{ entry_unavailable }}</span></label>
				<div class="col-sm-9">
				<div class="checkbox">
				    <label><input type="checkbox" id="unavailable" name="yandex_yml_unavailable" value="1"
                        {% if yandex_yml_unavailable %}checked="checked"{% endif %} />
                    </label>
				</div>
				</div>
			</div>
			
			<div class="form-group">
				<label class="col-sm-3 control-label" for="in-stock"><span data-toggle="tooltip" title="{{ entry_in_stock_help }}">
                    {{ entry_in_stock }}</span>
                </label>
				<div class="col-sm-9">
					<select name="yandex_yml_in_stock[]" id="in_stock"{% if yandex_yml_unavailable %} disabled="disabled"{% endif %} class="form-control" multiple="true" size="4">
                    {% for stock_status in stock_statuses %}
                        {%if stock_status.stock_status_id in yandex_yml_in_stock %}
					   <option value="{{ stock_status.stock_status_id }}" selected="selected">{{ stock_status.name }}</option>
					   {% else %}
